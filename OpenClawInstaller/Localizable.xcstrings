    "Isolated: each run in a separate session. Main: reuse the main session.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隔离：每次运行使用独立会话。主会话：复用主会话。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隔離：每次執行使用獨立會話。主會話：複用主會話。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "分離: 毎回別々のセッションで実行。メイン: メインセッションを再利用。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "격리: 매번 별도 세션에서 실행. 메인: 메인 세션을 재사용."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Isolé : chaque exécution dans une session séparée. Principal : réutiliser la session principale."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Isoliert: jeder Lauf in einer separaten Sitzung. Haupt: Hauptsitzung wiederverwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aislado: cada ejecución en una sesión separada. Principal: reutilizar la sesión principal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Isolato: ogni esecuzione in una sessione separata. Principale: riutilizza la sessione principale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isolado: cada execução em uma sessão separada. Principal: reutilizar a sessão principal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Изолированный: каждый запуск в отдельной сессии. Основной: повторное использование основной сессии."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معزول: كل تشغيل في جلسة منفصلة. رئيسي: إعادة استخدام الجلسة الرئيسية."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İzole: her çalışma ayrı oturumda. Ana: ana oturumu yeniden kullan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แยกเดี่ยว: แต่ละครั้งใช้เซสชันแยก หลัก: ใช้เซสชันหลักซ้ำ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tách biệt: mỗi lần chạy trong phiên riêng. Chính: tái sử dụng phiên chính."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Izolowany: każde uruchomienie w osobnej sesji. Główny: ponowne użycie głównej sesji."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geïsoleerd: elke uitvoering in een aparte sessie. Hoofd: hoofdsessie hergebruiken."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Isolerad: varje körning i en separat session. Huvud: återanvänd huvudsessionen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Isoleret: hver kørsel i en separat session. Hoved: genbrug hovedsessionen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Eristetty: jokainen ajo omassa istunnossa. Pää: käytä pääistuntoa uudelleen."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Elkülönített: minden futás külön munkamenetben. Fő: a fő munkamenet újrahasználata."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απομονωμένο: κάθε εκτέλεση σε ξεχωριστή συνεδρία. Κύριο: επαναχρήση κύριας συνεδρίας."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terisolasi: setiap eksekusi di sesi terpisah. Utama: gunakan ulang sesi utama."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Terpencil: setiap larian dalam sesi berasingan. Utama: guna semula sesi utama."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Isolated: bawat run sa hiwalay na session. Pangunahin: gamitin muli ang pangunahing session."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "ایزوله: هر اجرا در جلسه جداگانه. اصلی: استفاده مجدد از جلسه اصلی."
          }
        }
      }
    },
