    "No models configured. Add models or select a provider preset.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد نماذج مُعدَّة. أضف نماذج أو اختر إعدادًا مسبقًا لمزود."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen modeller konfigureret. Tilføj modeller, eller vælg en udbyderforudindstilling."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Modelle konfiguriert. Fügen Sie Modelle hinzu oder wählen Sie eine Anbieter-Voreinstellung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν έχουν διαμορφωθεί μοντέλα. Προσθέστε μοντέλα ή επιλέξτε μια προεπιλογή παρόχου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay modelos configurados. Añade modelos o selecciona un proveedor preconfigurado."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "هیچ مدلی پیکربندی نشده است. مدل‌ها را اضافه کنید یا یک پیش‌تنظیم ارائه‌دهنده انتخاب کنید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Malleja ei ole määritetty. Lisää malleja tai valitse tarjoajan esiasetus."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun modèle configuré. Ajoutez des modèles ou sélectionnez un fournisseur prédéfini."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincsenek beállított modellek. Adjon hozzá modelleket, vagy válasszon egy szolgáltató előbeállítást."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada model yang dikonfigurasi. Tambahkan model atau pilih preset penyedia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun modello configurato. Aggiungi modelli o seleziona un preset del fornitore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルが設定されていません。モデルを追加するか、プロバイダーのプリセットを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구성된 모델이 없습니다. 모델을 추가하거나 공급자 프리셋을 선택하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada model dikonfigurasi. Tambah model atau pilih pratetap pembekal."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen modellen geconfigureerd. Voeg modellen toe of selecteer een aanbiedervoorinstelling."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum modelo configurado. Adicione modelos ou selecione um provedor pré-configurado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Модели не настроены. Добавьте модели или выберите предустановку поставщика."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inga modeller konfigurerade. Lägg till modeller eller välj en leverantörsförinställning."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่ได้กำหนดค่าโมเดล เพิ่มโมเดลหรือเลือกค่าเริ่มต้นของผู้ให้บริการ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapılandırılmış model yok. Model ekleyin veya bir sağlayıcı ön ayarı seçin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chưa cấu hình mô hình nào. Thêm mô hình hoặc chọn cấu hình nhà cung cấp có sẵn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未配置模型。请添加模型或选择提供商预设。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未設定模型。請新增模型或選擇供應商預設。"
          }
        }
      }
    },
