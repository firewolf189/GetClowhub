            "state": "translated",
            "value": "• 如果下载速度慢，请尝试使用 VPN"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "• 如果下載速度慢，請嘗試使用 VPN"
          }
        }
      }
    },
    "• Click 'Retry' to attempt installation again": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "• انقر على 'إعادة المحاولة' لمحاولة التثبيت مرة أخرى"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "• Klik på 'Prøv igen' for at forsøge installationen igen"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Klicken Sie auf „Erneut versuchen“, um die Installation erneut zu starten"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "• Κάντε κλικ στο «Επανάληψη» για να δοκιμάσετε ξανά την εγκατάσταση"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "• Haz clic en 'Reintentar' para intentar la instalación de nuevo"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "• برای تلاش مجدد نصب روی «تلاش دوباره» کلیک کنید"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "• Napsauta ”Yritä uudelleen” yrittääksesi asennusta uudelleen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Cliquez sur « Réessayer » pour tenter à nouveau l'installation"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "• Kattintson az „Újrapróbálás” gombra a telepítés ismételt megkísérléséhez"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "• Klik 'Coba Lagi' untuk mencoba instalasi kembali"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "• Fai clic su 'Riprova' per ritentare l'installazione"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "• 「リトライ」をクリックして再度インストールを試みてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "• '재시도'를 클릭하여 설치를 다시 시도하세요"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "• Klik 'Cuba Semula' untuk mencuba pemasangan sekali lagi"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Klik op 'Opnieuw proberen' om de installatie opnieuw te proberen"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "• Clique em 'Tentar novamente' para tentar a instalação novamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Нажмите «Повторить» для повторной попытки установки"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "• Klicka på \"Försök igen\" för att försöka installera igen"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "• คลิก 'ลองใหม่' เพื่อลองติดตั้งอีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Kurulumu tekrar denemek için 'Yeniden Dene' düğmesine tıklayın"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "• Nhấn 'Thử lại' để thực hiện cài đặt lần nữa"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "• 点击“重试”再次尝试安装"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "• 點擊「重試」再次嘗試安裝"
          }
        }
      }
    },
