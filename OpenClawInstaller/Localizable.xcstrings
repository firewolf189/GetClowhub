    "This wizard will guide you through installing OpenClaw on your Mac": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيرشدك هذا المعالج خلال تثبيت OpenClaw على جهاز Mac الخاص بك"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne guide hjælper dig med at installere OpenClaw på din Mac"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Assistent führt Sie durch die Installation von OpenClaw auf Ihrem Mac"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτός ο οδηγός θα σας καθοδηγήσει στην εγκατάσταση του OpenClaw στο Mac σας"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este asistente le guiará en la instalación de OpenClaw en su Mac"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این راهنما شما را در نصب OpenClaw بر روی Mac راهنمایی می‌کند"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä ohjattu toiminto opastaa sinua asentamaan OpenClaw Mac-tietokoneellesi"
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Gagabayan ka ng wizard na ito sa pag-install ng OpenClaw sa iyong Mac"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet assistant vous guidera lors de l'installation d'OpenClaw sur votre Mac"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a varázsló végigvezeti az OpenClaw telepítésén a Mac-en"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Wizard ini akan memandu Anda menginstal OpenClaw di Mac Anda"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa procedura guidata ti aiuterà a installare OpenClaw sul tuo Mac"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このウィザードでは、Mac に OpenClaw をインストールする手順を案内します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 마법사가 Mac에 OpenClaw를 설치하는 과정을 안내합니다"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Wizard ini akan membimbing anda memasang OpenClaw pada Mac anda"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze wizard begeleidt u bij het installeren van OpenClaw op uw Mac"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten kreator przeprowadzi Cię przez instalację OpenClaw na Twoim Macu"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este assistente irá guiá-lo na instalação do OpenClaw no seu Mac"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот мастер проведёт вас через установку OpenClaw на вашем Mac"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den här guiden hjälper dig att installera OpenClaw på din Mac"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตัวช่วยนี้จะแนะนำคุณในการติดตั้ง OpenClaw บน Mac ของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu sihirbaz, Mac'inize OpenClaw kurulumu boyunca size rehberlik edecektir"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trình hướng dẫn này sẽ giúp bạn cài đặt OpenClaw trên máy Mac"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本向导将引导您在 Mac 上安装 OpenClaw"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本精靈將引導您在 Mac 上安裝 OpenClaw"
          }
        }
      }
    },
