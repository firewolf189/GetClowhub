    "For Telegram/Discord: bot token. For Slack: bot token (xoxb-...). Other channels may require different credentials.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لـ Telegram/Discord: رمز البوت. لـ Slack: رمز البوت (xoxb-...). قد تتطلب القنوات الأخرى بيانات اعتماد مختلفة."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Til Telegram/Discord: bot-token. Til Slack: bot-token (xoxb-...). Andre kanaler kan kræve andre legitimationsoplysninger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für Telegram/Discord: Bot-Token. Für Slack: Bot-Token (xoxb-...). Andere Kanäle erfordern möglicherweise andere Anmeldedaten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Για Telegram/Discord: διακριτικό bot. Για Slack: διακριτικό bot (xoxb-...). Άλλα κανάλια ενδέχεται να απαιτούν διαφορετικά διαπιστευτήρια."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para Telegram/Discord: token del bot. Para Slack: token del bot (xoxb-...). Otros canales pueden requerir credenciales diferentes."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای Telegram/Discord: توکن ربات. برای Slack: توکن ربات (xoxb-...). کانال‌های دیگر ممکن است اعتبارنامه‌های متفاوتی نیاز داشته باشند."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram/Discord: botin tunniste. Slack: botin tunniste (xoxb-...). Muut kanavat voivat vaatia eri tunnistetietoja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour Telegram/Discord : jeton du bot. Pour Slack : jeton du bot (xoxb-...). D'autres canaux peuvent nécessiter des identifiants différents."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram/Discord esetén: bot token. Slack esetén: bot token (xoxb-...). Más csatornák eltérő hitelesítő adatokat igényelhetnek."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk Telegram/Discord: token bot. Untuk Slack: token bot (xoxb-...). Kanal lain mungkin memerlukan kredensial yang berbeda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per Telegram/Discord: token del bot. Per Slack: token del bot (xoxb-...). Altri canali potrebbero richiedere credenziali diverse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram/Discord の場合: ボットトークン。Slack の場合: ボットトークン (xoxb-...)。他のチャンネルでは異なる認証情報が必要な場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram/Discord: 봇 토큰. Slack: 봇 토큰 (xoxb-...). 다른 채널은 다른 자격 증명이 필요할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk Telegram/Discord: token bot. Untuk Slack: token bot (xoxb-...). Saluran lain mungkin memerlukan kelayakan yang berbeza."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voor Telegram/Discord: bottoken. Voor Slack: bottoken (xoxb-...). Andere kanalen vereisen mogelijk andere inloggegevens."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para Telegram/Discord: token do bot. Para Slack: token do bot (xoxb-...). Outros canais podem exigir credenciais diferentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для Telegram/Discord: токен бота. Для Slack: токен бота (xoxb-...). Другие каналы могут требовать иные учётные данные."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För Telegram/Discord: bot-token. För Slack: bot-token (xoxb-...). Andra kanaler kan kräva andra uppgifter."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สำหรับ Telegram/Discord: โทเค็นบอท สำหรับ Slack: โทเค็นบอท (xoxb-...) ช่องทางอื่นอาจต้องใช้ข้อมูลรับรองที่แตกต่างกัน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram/Discord için: bot jetonu. Slack için: bot jetonu (xoxb-...). Diğer kanallar farklı kimlik bilgileri gerektirebilir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
