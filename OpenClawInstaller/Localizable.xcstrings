    "Format: minute hour day month weekday (e.g. \"0 9 * * *\" = every day at 9:00 AM)": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "格式：分 时 日 月 星期（例如 \"0 9 * * *\" = 每天 9:00）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "格式：分 時 日 月 星期（例如 \"0 9 * * *\" = 每天 9:00）"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "形式: 分 時 日 月 曜日（例: \"0 9 * * *\" = 毎日9:00）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "형식: 분 시 일 월 요일 (예: \"0 9 * * *\" = 매일 9:00)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Format : minute heure jour mois jour_semaine (ex. \"0 9 * * *\" = tous les jours à 9h00)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: Minute Stunde Tag Monat Wochentag (z.B. \"0 9 * * *\" = täglich um 9:00)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato: minuto hora día mes día_semana (ej. \"0 9 * * *\" = todos los días a las 9:00)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato: minuto ora giorno mese giorno_sett (es. \"0 9 * * *\" = ogni giorno alle 9:00)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato: minuto hora dia mês dia_semana (ex. \"0 9 * * *\" = todos os dias às 9:00)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Формат: минута час день месяц день_недели (напр. \"0 9 * * *\" = каждый день в 9:00)"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الصيغة: دقيقة ساعة يوم شهر يوم_أسبوع (مثلاً \"0 9 * * *\" = كل يوم الساعة 9:00)"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: dakika saat gün ay haftanın_günü (ör. \"0 9 * * *\" = her gün 9:00)"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รูปแบบ: นาที ชั่วโมง วัน เดือน วันในสัปดาห์ (เช่น \"0 9 * * *\" = ทุกวัน 9:00)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Định dạng: phút giờ ngày tháng thứ (ví dụ \"0 9 * * *\" = mỗi ngày lúc 9:00)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: minuta godzina dzień miesiąc dzień_tygodnia (np. \"0 9 * * *\" = codziennie o 9:00)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Formaat: minuut uur dag maand weekdag (bijv. \"0 9 * * *\" = elke dag om 9:00)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: minut timme dag månad veckodag (t.ex. \"0 9 * * *\" = varje dag kl. 9:00)"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: minut time dag måned ugedag (f.eks. \"0 9 * * *\" = hver dag kl. 9:00)"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Muoto: minuutti tunti päivä kuukausi viikonpäivä (esim. \"0 9 * * *\" = joka päivä klo 9:00)"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Formátum: perc óra nap hónap hét_napja (pl. \"0 9 * * *\" = minden nap 9:00-kor)"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μορφή: λεπτό ώρα ημέρα μήνας ημέρα_εβδομάδας (π.χ. \"0 9 * * *\" = κάθε μέρα στις 9:00)"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: menit jam hari bulan hari_minggu (cth. \"0 9 * * *\" = setiap hari jam 9:00)"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: minit jam hari bulan hari_minggu (cth. \"0 9 * * *\" = setiap hari jam 9:00)"
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: minuto oras araw buwan araw_linggo (hal. \"0 9 * * *\" = araw-araw 9:00 AM)"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "فرمت: دقیقه ساعت روز ماه روز_هفته (مثلاً \"0 9 * * *\" = هر روز ساعت 9:00)"
          }
        }
      }
    },
