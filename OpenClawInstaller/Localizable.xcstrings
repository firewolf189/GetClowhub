          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Waarom is een token nodig?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por que é necessário um token?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Зачем нужен токен?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Varför behövs en token?"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ทำไมต้องใช้โทเค็น?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Neden bir jeton gerekli?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tại sao cần mã xác thực?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为什么需要令牌？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為什麼需要令牌？"
          }
        }
      }
    },
    "The auth token protects your gateway from unauthorized access. It will be written to ~/.openclaw/openclaw.json and used when opening the dashboard.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحمي رمز المصادقة بوابتك من الوصول غير المُصرَّح به. سيُكتب في ~/.openclaw/openclaw.json ويُستخدم عند فتح لوحة التحكم."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Godkendelsestokenet beskytter din gateway mod uautoriseret adgang. Det vil blive skrevet til ~/.openclaw/openclaw.json og bruges ved åbning af kontrolpanelet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Authentifizierungstoken schützt Ihr Gateway vor unbefugtem Zugriff. Es wird in ~/.openclaw/openclaw.json gespeichert und beim Öffnen des Dashboards verwendet."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το διακριτικό ταυτοποίησης προστατεύει την πύλη σας από μη εξουσιοδοτημένη πρόσβαση. Θα αποθηκευτεί στο ~/.openclaw/openclaw.json και θα χρησιμοποιείται κατά το άνοιγμα του πίνακα ελέγχου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El token de autenticación protege tu gateway de accesos no autorizados. Se escribirá en ~/.openclaw/openclaw.json y se usará al abrir el panel de control."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "توکن احراز هویت از درگاه شما در برابر دسترسی غیرمجاز محافظت می‌کند. این توکن در فایل ~/.openclaw/openclaw.json ذخیره شده و هنگام باز کردن داشبورد استفاده می‌شود."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Todennustunniste suojaa yhdyskäytävääsi luvattomalta käytöltä. Se kirjoitetaan tiedostoon ~/.openclaw/openclaw.json ja sitä käytetään hallintapaneelia avattaessa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le jeton d'authentification protège votre passerelle contre les accès non autorisés. Il sera enregistré dans ~/.openclaw/openclaw.json et utilisé lors de l'ouverture du tableau de bord."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hitelesítési token védi az átjárót az illetéktelen hozzáféréstől. A ~/.openclaw/openclaw.json fájlba kerül mentésre, és a vezérlőpult megnyitásakor használatos."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Token autentikasi melindungi gateway Anda dari akses tidak sah. Token akan ditulis ke ~/.openclaw/openclaw.json dan digunakan saat membuka dasbor."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il token di autenticazione protegge il tuo gateway da accessi non autorizzati. Verrà scritto in ~/.openclaw/openclaw.json e utilizzato all'apertura della dashboard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証トークンはゲートウェイへの不正アクセスを防ぎます。~/.openclaw/openclaw.json に書き込まれ、ダッシュボードを開く際に使用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인증 토큰은 게이트웨이를 무단 접근으로부터 보호합니다. ~/.openclaw/openclaw.json에 기록되며 대시보드를 열 때 사용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Token pengesahan melindungi gerbang anda daripada akses tanpa kebenaran. Ia akan ditulis ke ~/.openclaw/openclaw.json dan digunakan semasa membuka papan pemuka."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het verificatietoken beschermt uw gateway tegen ongeautoriseerde toegang. Het wordt opgeslagen in ~/.openclaw/openclaw.json en gebruikt bij het openen van het dashboard."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O token de autenticação protege seu gateway contra acessos não autorizados. Ele será gravado em ~/.openclaw/openclaw.json e usado ao abrir o painel de controle."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Токен авторизации защищает ваш шлюз от несанкционированного доступа. Он будет записан в ~/.openclaw/openclaw.json и использоваться при открытии панели управления."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Autentiseringstoken skyddar din gateway från obehörig åtkomst. Den skrivs till ~/.openclaw/openclaw.json och används när kontrollpanelen öppnas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โทเค็นยืนยันตัวตนจะปกป้องเกตเวย์ของคุณจากการเข้าถึงที่ไม่ได้รับอนุญาต โทเค็นจะถูกเขียนลงใน ~/.openclaw/openclaw.json และใช้เมื่อเปิดแดชบอร์ด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kimlik doğrulama jetonu, ağ geçidinizi yetkisiz erişimden korur. ~/.openclaw/openclaw.json dosyasına yazılacak ve pano açılırken kullanılacaktır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mã xác thực bảo vệ cổng kết nối của bạn khỏi truy cập trái phép. Nó sẽ được ghi vào ~/.openclaw/openclaw.json và được sử dụng khi mở bảng điều khiển."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证令牌保护您的网关免受未经授权的访问。它将写入 ~/.openclaw/openclaw.json 并在打开控制台时使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "身分驗證令牌保護您的閘道器免受未經授權的存取。它將寫入 ~/.openclaw/openclaw.json 並在開啟控制台時使用。"
          }
        }
      }
    },
