    "This will remove OpenClaw, Node.js runtime and log files.\nConfiguration and login data will be preserved.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى حذف برنامج OpenClaw وبيئة Node.js وملفات السجل.\nسيتم الاحتفاظ بملفات الإعداد وبيانات تسجيل الدخول."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil fjerne OpenClaw, Node.js-runtime og logfiler.\nKonfiguration og logindata bevares."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt OpenClaw, die Node.js-Laufzeitumgebung und Protokolldateien.\nKonfiguration und Anmeldedaten bleiben erhalten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό θα αφαιρέσει το OpenClaw, το Node.js και τα αρχεία καταγραφής.\nΟι ρυθμίσεις και τα δεδομένα σύνδεσης θα διατηρηθούν."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará OpenClaw, el entorno Node.js y los archivos de registro.\nLa configuración y los datos de inicio de sesión se conservarán."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این عملیات OpenClaw، محیط اجرای Node.js و فایل‌های گزارش را حذف می‌کند.\nتنظیمات و اطلاعات ورود حفظ خواهند شد."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä poistaa OpenClaw'n, Node.js-ajoympäristön ja lokitiedostot.\nAsetukset ja kirjautumistiedot säilytetään."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ire-remove nito ang OpenClaw, Node.js runtime at log files.\nMananatili ang configuration at login data."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci supprimera OpenClaw, l'environnement Node.js et les fichiers journaux.\nLa configuration et les données de connexion seront conservées."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez eltávolítja az OpenClaw-t, a Node.js futtatókörnyezetet és a naplófájlokat.\nA beállítások és bejelentkezési adatok megőrződnek."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan menghapus OpenClaw, runtime Node.js, dan file log.\nKonfigurasi dan data login akan dipertahankan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuoverà OpenClaw, il runtime Node.js e i file di log.\nConfigurazione e dati di accesso saranno conservati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw、Node.jsランタイム、ログファイルが削除されます。\n設定ファイルとログイン情報は保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw, Node.js 런타임 및 로그 파일이 삭제됩니다.\n설정 파일과 로그인 정보는 보존됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan membuang OpenClaw, runtime Node.js dan fail log.\nKonfigurasi dan data log masuk akan dikekalkan."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit verwijdert OpenClaw, de Node.js-runtime en logbestanden.\nConfiguratie en inloggegevens worden bewaard."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to usunięcie OpenClaw, środowiska Node.js i plików logów.\nKonfiguracja i dane logowania zostaną zachowane."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso removerá o OpenClaw, o runtime Node.js e os arquivos de log.\nA configuração e os dados de login serão preservados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Будут удалены OpenClaw, среда выполнения Node.js и файлы журналов.\nФайлы конфигурации и данные входа будут сохранены."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta tar bort OpenClaw, Node.js-runtime och loggfiler.\nKonfiguration och inloggningsdata bevaras."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จะลบ OpenClaw, Node.js runtime และไฟล์ log\nไฟล์การตั้งค่าและข้อมูลการเข้าสู่ระบบจะถูกเก็บรักษาไว้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem OpenClaw, Node.js çalışma zamanı ve günlük dosyalarını kaldıracaktır.\nYapılandırma ve giriş verileri korunacaktır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa OpenClaw, runtime Node.js và các file log.\nCấu hình và dữ liệu đăng nhập sẽ được giữ lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将删除 OpenClaw 程序、Node.js 运行环境和日志文件。\n配置文件和登录信息会保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將刪除 OpenClaw 程式、Node.js 執行環境和日誌檔案。\n設定檔和登入資訊會保留。"
          }
        }
      }
    },
    "Log Out": {
      "localizations": {
        "ar": {
