    "• Ensure Node.js is properly installed": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "• تأكد من أن Node.js مُثبَّت بشكل صحيح"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "• Sørg for, at Node.js er korrekt installeret"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Stellen Sie sicher, dass Node.js korrekt installiert ist"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "• Βεβαιωθείτε ότι το Node.js είναι σωστά εγκατεστημένο"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "• Asegúrate de que Node.js esté correctamente instalado"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "• از نصب صحیح Node.js اطمینان حاصل کنید"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "• Varmista, että Node.js on asennettu oikein"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Assurez-vous que Node.js est correctement installé"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "• Győződjön meg arról, hogy a Node.js megfelelően van telepítve"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "• Pastikan Node.js terinstal dengan benar"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "• Assicurati che Node.js sia installato correttamente"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "• Node.js が正しくインストールされていることを確認してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "• Node.js가 올바르게 설치되어 있는지 확인하세요"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "• Pastikan Node.js dipasang dengan betul"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Zorg ervoor dat Node.js correct is geïnstalleerd"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "• Certifique-se de que o Node.js está instalado corretamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Убедитесь, что Node.js установлен корректно"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "• Kontrollera att Node.js är korrekt installerat"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "• ตรวจสอบว่า Node.js ถูกติดตั้งอย่างถูกต้อง"
          }
        },
        "tr": {
          "stringUnit": {
