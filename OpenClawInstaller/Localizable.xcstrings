        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skift af udbyder vil erstatte den nuværende basis-URL og modelliste. API-nøglen vil blive slettet. Fortsæt?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Anbieterwechsel ersetzt die aktuelle Basis-URL und Modellliste. Der API-Schlüssel wird gelöscht. Fortfahren?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αλλαγή παρόχου θα αντικαταστήσει το τρέχον βασικό URL και τη λίστα μοντέλων. Το κλειδί API θα διαγραφεί. Συνέχεια;"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambiar de proveedor reemplazará la URL base y la lista de modelos actuales. La clave de API se borrará. ¿Continuar?"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "تغییر ارائه‌دهنده، آدرس پایه فعلی و لیست مدل‌ها را جایگزین می‌کند. کلید API پاک خواهد شد. ادامه می‌دهید؟"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarjoajan vaihtaminen korvaa nykyisen perus-URL:n ja malliluettelon. API-avain tyhjennetään. Jatketaanko?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le changement de fournisseur remplacera l'URL de base et la liste de modèles actuels. La clé API sera effacée. Continuer ?"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A szolgáltató váltása lecseréli a jelenlegi alap URL-t és modelllistát. Az API kulcs törlődik. Folytatja?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengganti penyedia akan menggantikan URL Dasar dan daftar model saat ini. Kunci API akan dihapus. Lanjutkan?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il cambio di fornitore sostituirà l'URL base corrente e l'elenco dei modelli. La chiave API verrà cancellata. Continuare?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダーを切り替えると、現在のベース URL とモデルリストが置き換えられます。API キーはクリアされます。続行しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공급자를 전환하면 현재 기본 URL과 모델 목록이 교체됩니다. API 키가 지워집니다. 계속하시겠습니까?"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menukar pembekal akan menggantikan URL Asas semasa dan senarai model. Kunci API akan dikosongkan. Teruskan?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het wisselen van aanbieder vervangt de huidige basis-URL en modellijst. De API-sleutel wordt gewist. Doorgaan?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Trocar de provedor substituirá a URL base e a lista de modelos atuais. A chave de API será apagada. Continuar?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смена поставщика заменит текущий базовый URL и список моделей. Ключ API будет очищен. Продолжить?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Byte av leverantör ersätter nuvarande basadress och modelllista. API-nyckeln raderas. Fortsätta?"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเปลี่ยนผู้ให้บริการจะแทนที่ URL ฐานและรายการโมเดลปัจจุบัน คีย์ API จะถูกล้าง ดำเนินการต่อ?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlayıcı değiştirmek mevcut Temel URL ve model listesini değiştirecektir. API Anahtarı temizlenecektir. Devam edilsin mi?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chuyển nhà cung cấp sẽ thay thế URL cơ sở và danh sách mô hình hiện tại. Khóa API sẽ bị xóa. Tiếp tục?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换提供商将替换当前的基础 URL 和模型列表。API 密钥将被清除。是否继续？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換供應商將替換目前的基礎 URL 和模型列表。API 金鑰將被清除。是否繼續？"
          }
        }
      }
    },
