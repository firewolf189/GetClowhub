    "You bring ideas, I build repos and ship to stars": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت تأتي بالأفكار، وأنا أبني المستودعات وأوصلها للنجوم"
          }
