    "This token is required to access the OpenClaw dashboard and API. You can change it later in the configuration page.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الرمز مطلوب للوصول إلى لوحة تحكم OpenClaw وواجهة برمجة التطبيقات. يمكنك تغييره لاحقًا في صفحة الإعدادات."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette token er påkrævet for at få adgang til OpenClaw-kontrolpanelet og API'et. Du kan ændre det senere på konfigurationssiden."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Token wird für den Zugriff auf das OpenClaw-Dashboard und die API benötigt. Sie können es später auf der Konfigurationsseite ändern."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό το διακριτικό απαιτείται για πρόσβαση στον πίνακα ελέγχου και το API του OpenClaw. Μπορείτε να το αλλάξετε αργότερα στη σελίδα διαμόρφωσης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este token es necesario para acceder al panel de control y la API de OpenClaw. Puedes cambiarlo después en la página de configuración."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این توکن برای دسترسی به داشبورد و API OpenClaw ضروری است. می‌توانید بعداً آن را در صفحه پیکربندی تغییر دهید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä tunniste vaaditaan OpenClaw-hallintapaneelin ja API:n käyttämiseen. Voit muuttaa sen myöhemmin asetussivulla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce jeton est nécessaire pour accéder au tableau de bord et à l'API d'OpenClaw. Vous pourrez le modifier ultérieurement dans la page de configuration."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a token szükséges az OpenClaw vezérlőpult és API eléréséhez. Később módosíthatja a beállítások oldalon."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Token ini diperlukan untuk mengakses dasbor dan API OpenClaw. Anda dapat mengubahnya nanti di halaman konfigurasi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo token è necessario per accedere alla dashboard e all'API di OpenClaw. Puoi modificarlo in seguito nella pagina di configurazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このトークンは OpenClaw ダッシュボードと API へのアクセスに必要です。後から設定ページで変更できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 토큰은 OpenClaw 대시보드 및 API에 접근하는 데 필요합니다. 나중에 구성 페이지에서 변경할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Token ini diperlukan untuk mengakses papan pemuka dan API OpenClaw. Anda boleh menukarnya kemudian di halaman konfigurasi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit token is vereist voor toegang tot het OpenClaw-dashboard en de API. U kunt het later wijzigen op de configuratiepagina."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este token é necessário para acessar o painel de controle e a API do OpenClaw. Você pode alterá-lo depois na página de configuração."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот токен необходим для доступа к панели управления и API OpenClaw. Вы можете изменить его позже на странице настроек."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna token krävs för att komma åt OpenClaw-kontrollpanelen och API:et. Du kan ändra den senare på konfigurationssidan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โทเค็นนี้จำเป็นสำหรับการเข้าถึงแดชบอร์ดและ API ของ OpenClaw คุณสามารถเปลี่ยนได้ภายหลังในหน้าการกำหนดค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu jeton, OpenClaw panosuna ve API'ye erişmek için gereklidir. Daha sonra yapılandırma sayfasında değiştirebilirsiniz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mã xác thực này cần thiết để truy cập bảng điều khiển và API của OpenClaw. Bạn có thể thay đổi sau trong trang cấu hình."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此令牌用于访问 OpenClaw 控制台和 API。您可以稍后在配置页面中更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此令牌用於存取 OpenClaw 控制台和 API。您可以稍後在設定頁面中變更。"
          }
        }
      }
    },
