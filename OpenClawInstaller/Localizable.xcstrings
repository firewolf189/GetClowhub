    "The task timed out and has been terminated. You can try again or switch to another agent.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انتهت مهلة المهمة وتم إنهاؤها. يمكنك المحاولة مرة أخرى أو التبديل إلى وكيل آخر."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Opgaven fik timeout og blev afsluttet. Du kan prøve igen eller skifte til en anden agent."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Aufgabe wurde wegen Zeitüberschreitung beendet. Sie können es erneut versuchen oder zu einem anderen Agenten wechseln."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εργασία έληξε και τερματίστηκε. Μπορείτε να δοκιμάσετε ξανά ή να μεταβείτε σε άλλον agent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La tarea agotó el tiempo de espera y fue terminada. Puedes intentarlo de nuevo o cambiar a otro agente."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "وظیفه به دلیل پایان زمان متوقف شد. می‌توانید دوباره تلاش کنید یا به عامل دیگری بروید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tehtävä aikakatkaistiin ja lopetettiin. Voit yrittää uudelleen tai vaihtaa toiseen agenttiin."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Nag-timeout ang task at tinigil na ito. Maaari kang subukang muli o lumipat sa ibang agent."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La tâche a expiré et a été interrompue. Vous pouvez réessayer ou passer à un autre agent."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A feladat időtúllépés miatt leállt. Próbáld újra vagy válts másik ágenst."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tugas kehabisan waktu dan dihentikan. Anda bisa mencoba lagi atau beralih ke agen lain."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'attività è scaduta ed è stata terminata. Puoi riprovare o passare a un altro agente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクがタイムアウトし、終了しました。再試行するか、別のエージェントに切り替えてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업이 시간 초과되어 종료되었습니다. 다시 시도하거나 다른 에이전트로 전환할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tugas tamat masa dan telah dihentikan. Anda boleh cuba lagi atau bertukar kepada ejen lain."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De taak is verlopen en beëindigd. Je kunt het opnieuw proberen of naar een andere agent wisselen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadanie przekroczyło limit czasu i zostało zakończone. Możesz spróbować ponownie lub przełączyć się na innego agenta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A tarefa expirou e foi encerrada. Você pode tentar novamente ou mudar para outro agente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Время выполнения задачи истекло, и она была завершена. Вы можете попробовать снова или переключиться на другого агента."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Uppgiften tog för lång tid och avbröts. Du kan försöka igen eller byta till en annan agent."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "งานหมดเวลาและถูกยุติ คุณสามารถลองใหม่หรือเปลี่ยนไปใช้ agent อื่น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Görev zaman aşımına uğradı ve sonlandırıldı. Tekrar deneyebilir veya başka bir ajana geçebilirsiniz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tác vụ đã hết thời gian và bị dừng. Bạn có thể thử lại hoặc chuyển sang agent khác."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "任务已超时并被终止。你可以重试或切换到其他 agent。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "任務已逾時並被終止。你可以重試或切換到其他 agent。"
          }
        }
      }
    },
